# Normalize text files to LF in the repository.
* text=auto eol=lf

# Keep Windows shell scripts with CRLF when needed.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common text-based project files.
*.py text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary assets should never be normalized.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
